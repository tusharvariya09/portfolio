@page "/"
<PageTitle>Tushar Variya | .NET Developer</PageTitle>

<div class="home-hero">
    <div class="hero-grid"></div>
    <div class="home-hero-inner">
        <div class="hero-badge">
            <span class="hero-dot"></span>
            Available for opportunities
        </div>
        <h1 class="hero-name">
            Hi, I'm<br />
            <span class="hero-name-accent">Tushar Variya</span>
        </h1>
        <p class="hero-role">Software Developer &middot; <b>ASP.NET Core &amp; C#</b> Specialist</p>
        <p class="hero-desc">
            Building secure, scalable web applications and RESTful APIs with .NET.
            2+ years crafting backend systems with clean architecture, SOLID principles,
            and modern DevOps practices from Surat, India.
        </p>
        <div class="hero-cta">
            <a href="/projects" class="btn-primary">
                <i class="fas fa-diagram-project"></i> View Projects
            </a>
            <a href="/contact" class="btn-outline">
                <i class="fas fa-envelope"></i> Get In Touch
            </a>
            <a href="/resume/TusharVariya_Resume.pdf" download class="btn-outline">
                <i class="fas fa-download"></i> Resume
            </a>
        </div>
        <div class="hero-stats">
            <div><span class="stat-num">2+</span><span class="stat-label">Years Experience</span></div>
            <div><span class="stat-num">10+</span><span class="stat-label">Projects Built</span></div>
            <div><span class="stat-num">5+</span><span class="stat-label">Technologies</span></div>
            <div><span class="stat-num">100%</span><span class="stat-label">Dedication</span></div>
        </div>
    </div>
</div>
